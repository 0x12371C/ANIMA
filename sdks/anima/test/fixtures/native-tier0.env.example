# ANIMA Native Tier 0 local strict-private runtime fixture template (LB-11 scaffold)
# Placeholders only. Do not commit secrets.
# VM-first privacy architecture: Active VeilVM only.
# EVM rails are compatibility-only and should remain disabled for default strict-private runs.
# Live flow harness execution is pending until implementation lands.

# Runtime mode
ANIMA_NATIVE_RUNTIME=veilvm
ANIMA_NATIVE_MODE=strict-private
ANIMA_NATIVE_ENABLE_EVM_COMPAT=false
ANIMA_NATIVE_ALLOW_DEPRECATED_SURFACES=false

# Admitted Tier 0 action IDs for default mode (strict-private)
# Canonical ordered flow: CommitOrder(2) -> RevealBatch(3) -> SubmitBatchProof(17) -> ClearBatch(4)
ANIMA_NATIVE_TIER0_ADMITTED_ACTION_IDS=2,3,17,4
ANIMA_NATIVE_TIER0_ORDERED_FLOW_IDS=2,3,17,4

# Local VeilVM connectivity (replace placeholders for your local runtime)
VEILVM_RPC_URL=http://127.0.0.1:REPLACE_ME
VEILVM_WS_URL=ws://127.0.0.1:REPLACE_ME
VEILVM_CHAIN_ID=REPLACE_ME
# Local strict-private prerequisites (required for future LB-11 live execution)
# Committee config and runtime-state notes are placeholders until local harness/executor wiring lands.
VEILVM_COMMITTEE_CONFIG_PATH=REPLACE_ME
VEILVM_LOCAL_RUNTIME_STATE_NOTE=REPLACE_ME

# ANIMA / harness behavior
ANIMA_TIER0_TEST_TIMEOUT_MS=60000
ANIMA_TIER0_POLL_INTERVAL_MS=1000
ANIMA_TIER0_EVIDENCE_DIR=./test/artifacts/native-tier0
ANIMA_TIER0_EVIDENCE_NOTE=REPLACE_WITH_LOCAL_NOTE_PATH

# Strict-private admitted Tier 0 identities (Tier 0 only; placeholders)
# Use your local admitted ZeroID values or equivalent runtime identifiers.
TIER0_ZEROID_COMMIT_ORDER=did:veil:zeroid:REPLACE_ME_COMMIT_ORDER
TIER0_ZEROID_REVEAL_BATCH=did:veil:zeroid:REPLACE_ME_REVEAL_BATCH
TIER0_ZEROID_SUBMIT_BATCH_PROOF=did:veil:zeroid:REPLACE_ME_SUBMIT_BATCH_PROOF
TIER0_ZEROID_CLEAR_BATCH=did:veil:zeroid:REPLACE_ME_CLEAR_BATCH

# Signer roles (local-only secrets; leave blank in template)
# Depending on your runtime, one key may serve multiple roles. Keep role mapping explicit.
TIER0_SIGNER_COMMIT_ORDER_PRIVATE_KEY=REPLACE_ME
TIER0_SIGNER_REVEAL_BATCH_PRIVATE_KEY=REPLACE_ME
TIER0_SIGNER_SUBMIT_BATCH_PROOF_PRIVATE_KEY=REPLACE_ME
TIER0_SIGNER_CLEAR_BATCH_PRIVATE_KEY=REPLACE_ME

# Optional explicit addresses for validation/logging (placeholders)
TIER0_SIGNER_COMMIT_ORDER_ADDRESS=REPLACE_ME
TIER0_SIGNER_REVEAL_BATCH_ADDRESS=REPLACE_ME
TIER0_SIGNER_SUBMIT_BATCH_PROOF_ADDRESS=REPLACE_ME
TIER0_SIGNER_CLEAR_BATCH_ADDRESS=REPLACE_ME

# Optional proof/batch fixture inputs for local runs (placeholders)
TIER0_BATCH_ID=REPLACE_ME
TIER0_COMMIT_ORDER_PARAMS_PATH=REPLACE_ME
TIER0_BATCH_REVEAL_PAYLOAD_PATH=REPLACE_ME
TIER0_BATCH_PROOF_PATH=REPLACE_ME
TIER0_CLEAR_BATCH_PARAMS_PATH=REPLACE_ME
